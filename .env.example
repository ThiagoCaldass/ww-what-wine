# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ww_what_wine

# Backend
BACKEND_PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here_change_in_production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=WW - What Wine?

# Scraping
SCRAPER_ENABLED=false
SCRAPER_INTERVAL_HOURS=24

# Email (para confirmar subscription)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Payment (Stripe, PagSeguro, etc)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Analytics (opcional)
ANALYTICS_ID=your_google_analytics_id
